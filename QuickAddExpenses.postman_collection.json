{
	"info": {
		"_postman_id": "d1e2f3a4-b5c6-7d8e-9f0a-1b2c3d4e5f6g",
		"name": "Quick Add Expenses",
		"description": "Collection for testing the AI-powered Quick Add feature (Bulk Expense Addition).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Parse Raw Text",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"rawText\": \"Lunch 200, Taxi 150, Dinner 500\\nRent 5000\\nGym 1000\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/expense/parse-text",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"expense",
						"parse-text"
					]
				},
				"description": "Step 1: Paste unstructured text to get a parsed draft of expenses."
			},
			"response": []
		},
		{
			"name": "2. Confirm Bulk Add",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"verifiedExpenses\": [\n        {\n            \"description\": \"Lunch\",\n            \"amount\": 200,\n            \"category\": 1\n        },\n        {\n            \"description\": \"Taxi\",\n            \"amount\": 150,\n            \"category\": 2\n        },\n        {\n            \"description\": \"Dinner\",\n            \"amount\": 500,\n            \"category\": 1\n        }\n    ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/expense/bulk-add",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"expense",
						"bulk-add"
					]
				},
				"description": "Step 2: Send the verified list (after user review) to be saved in the database."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your_jwt_token_here",
			"type": "string"
		}
	]
}
